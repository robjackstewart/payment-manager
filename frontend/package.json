{
  "name": "payment-manager",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:aspire": "tsx scripts/generate-aspire-environment.ts && ng serve --configuration aspire",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "api-client:generate": "tsx scripts/generate-api-client.ts",
    "analyze": "ng build --source-map && npx source-map-explorer 'dist/payment-manager/browser/*.js' --no-border-checks"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "^21.2.3",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "ag-charts-community": "^13.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "angular-eslint": "^21.3.1",
    "jsdom": "^29.0.0",
    "source-map-explorer": "^2.5.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.8"
  }
}
