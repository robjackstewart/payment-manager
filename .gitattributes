# Default: normalise to LF in the repo, check out as native on each platform
* text=auto eol=lf

# Shell scripts must always be LF — CRLF breaks the shebang on Linux
*.sh text eol=lf

# Windows-only scripts can use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source code — LF everywhere
*.cs text eol=lf
*.csproj text eol=lf
*.slnx text eol=lf
*.props text eol=lf
*.ts text eol=lf
*.html text eol=lf
*.scss text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary files — no line-ending normalisation
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary
